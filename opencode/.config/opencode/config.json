{
  "$schema": "https://opencode.ai/config.json",
  "theme": "rosepine",
  "keybinds": {
    "leader": "ctrl+x",
    "editor_open": "<leader>e",
    "session_new": "<leader>n"
  },
  "autoupdate": true,
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "devstral:24b_16k": {
          "name": "Devstral"
        }
      }
    },
    "docker": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Docker Models",
      "options": {
        "baseURL": "http://localhost:12434/engines/llama.cpp/v1"
      },
      "models": {
        "ai/qwen3:latest": {
          "name": "Qwen3"
        }
      }
    }
  }
}
